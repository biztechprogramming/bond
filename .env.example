# Bond environment variables (optional — bond.json is preferred)

# Override bond home directory
# BOND_HOME=~/.bond

# LLM provider override
# BOND_LLM_PROVIDER=anthropic
# BOND_LLM_MODEL=claude-sonnet-4-20250514

# API keys (prefer vault via `bond setup`)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Backend
# BOND_BACKEND_HOST=127.0.0.1
# BOND_BACKEND_PORT=18790

# Gateway
# BOND_GATEWAY_HOST=127.0.0.1
# BOND_GATEWAY_PORT=18789

# Frontend
# BOND_FRONTEND_PORT=18788

# SpacetimeDB configuration
# Primary config is in bond.json. These env vars override bond.json values.
# SPACETIMEDB_URL=http://localhost:18787
# SPACETIMEDB_MODULE=bond-core-v2
#
# Authentication token is read automatically from ~/.config/spacetime/cli.toml
# (managed by `spacetime login`). Override with:
# SPACETIMEDB_TOKEN=

# Vault encryption key (auto-generated if not set)
# BOND_VAULT_KEY=
