{
  "name": "bond-gateway",
  "version": "0.1.0",
  "description": "Bond gateway — WebSocket server, channels, session management",
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--experimental-global-webcrypto' tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --experimental-global-webcrypto dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.61.1",
    "@slack/bolt": "^3.22.0",
    "@slack/web-api": "^7.9.0",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "discord.js": "^14.18.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "grammy": "^1.41.1",
    "js-yaml": "^4.1.1",
    "qrcode": "^1.5.4",
    "spacetimedb": "2.0.2",
    "ulid": "^3.0.2",
    "undici": "^7.22.0",
    "uuid": "^10.0.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
