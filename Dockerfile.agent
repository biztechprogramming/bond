# Bond Agent Worker — lightweight container for running agent turns.
# Design doc: 008-containerized-agent-runtime.md §15.4
#
# Usage:
#   docker build -f Dockerfile.agent -t bond-agent-worker .
#
# The Bond library is mounted read-only at /bond (not baked in),
# so code changes don't require image rebuilds — just restart the container.

FROM python:3.12-slim

# System deps: git (for agent git ops), curl (for health checks during debug), openssh-client (for git push)
RUN apt-get update && \
    apt-get install -y --no-install-recommends git curl openssh-client && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Mark /bond as safe for git operations
RUN git config --global --add safe.directory /bond

# Install uv for fast Python package management
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Python dependencies — install into system Python (no venv)
# These are the direct imports of worker.py + native tools
RUN pip install --no-cache-dir \
    aiosqlite \
    cryptography \
    fastapi \
    uvicorn \
    litellm \
    python-ulid \
    pydantic \
    httpx \
    mcp \
    anyio \
    langfuse

# Copy entrypoint script
COPY scripts/agent-entrypoint.sh /agent-entrypoint.sh
RUN chmod +x /agent-entrypoint.sh

# Create directories the worker expects
RUN mkdir -p /data /data/shared /config /workspace

# Bond library is mounted at /bond at runtime (read-only)
# Worker is invoked as: python -m backend.app.worker --port 18791
ENV PYTHONPATH=/bond

# Langfuse observability — connects to self-hosted instance
# These match the auto-init keys in docker-compose.langfuse.yml
ENV LANGFUSE_PUBLIC_KEY=pk-lf-bond-local
ENV LANGFUSE_SECRET_KEY=sk-lf-bond-local
ENV LANGFUSE_HOST=http://host.docker.internal:18786

# Patch: litellm passes sdk_integration to Langfuse() but langfuse v3
# removed that kwarg. This sitecustomize.py patches Langfuse.__init__
# before litellm auto-detects the env vars and tries to init a client.
RUN python3 -c "\
import sysconfig, pathlib; \
p = pathlib.Path(sysconfig.get_paths()['purelib']) / 'sitecustomize.py'; \
p.write_text( \
'import importlib\n' \
'try:\n' \
'    mod = importlib.import_module(\"langfuse._client.client\")\n' \
'    _L = getattr(mod, \"Langfuse\", None)\n' \
'    if _L:\n' \
'        _orig = _L.__init__\n' \
'        def _p(self, *a, **kw):\n' \
'            kw.pop(\"sdk_integration\", None)\n' \
'            return _orig(self, *a, **kw)\n' \
'        _L.__init__ = _p\n' \
'except Exception:\n' \
'    pass\n' \
)"

WORKDIR /bond

EXPOSE 18791

# Entrypoint handles git clone/pull, then execs worker
ENTRYPOINT ["/agent-entrypoint.sh"]
CMD ["--port", "18791", "--data-dir", "/data", "--config", "/config/agent.json"]
